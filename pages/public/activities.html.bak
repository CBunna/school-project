    <section class="hero" style="grid-template-rows: 300px;">
        <div class="hero-background"></div>
        <div class="hero-content">
            <h1>Activities in Beskydy</h1>
            <p class="hero-subtitle">Experience unforgettable adventure</p>
        </div>
    </section>

    <main id="main-content">
        <section class="container">
            <h2 class="section-title">Activities in Beskydy</h2>
            <p class="section-subtitle">Discover all year-round adventures</p>

            <div class="card-grid" id="activities-grid">
                <article class="card">
                    <div class="card-content">
                        <h3 class="card-title">🥾 Mountain Hiking</h3>
                        <p class="card-description">More than 750 miles of marked hiking trails for all difficulty levels. Walk the ridges, visit peaks or choose easy family trails through valleys.</p>
                        <ul class="info-list">
                            <li>Marked trails of all colors</li>
                            <li>Nature trails</li>
                            <li>Lookout towers with views</li>
                            <li>Mountain huts</li>
                        </ul>
                        <p><strong>Season:</strong> May - October</p>
                        <p><strong>Difficulty:</strong> Easy to challenging</p>
                    </div>
                </article>
                
                <article class="card">
                    <div class="card-content">
                        <h3 class="card-title">🚵 Mountain Biking</h3>
                        <p class="card-description">Hundreds of miles of bike paths and singletracks for road and mountain bikes. From family trips to adrenaline downhills.</p>
                        <ul class="info-list">
                            <li>Marked bike routes</li>
                            <li>Bikepark Malenovice</li>
                            <li>E-bike rentals</li>
                            <li>Service points</li>
                        </ul>
                        <p><strong>Season:</strong> April - October</p>
                        <p><strong>Difficulty:</strong> Easy to extreme</p>
                    </div>
                </article>
                
                <article class="card">
                    <div class="card-content">
                        <h3 class="card-title">🏊 Water Activities</h3>
                        <p class="card-description">Recreational dams, aqua parks and natural swimming pools for refreshment in hot summer days.</p>
                        <ul class="info-list">
                            <li>Šance Dam</li>
                            <li>Aquapark Frenštát</li>
                            <li>Natural swimming pools</li>
                            <li>Swimming and paddleboarding</li>
                        </ul>
                        <p><strong>Season:</strong> June - August</p>
                        <p><strong>Difficulty:</strong> Easy</p>
                    </div>
                </article>
            </div>
        </section>

        <section style="background: var(--bg-light); padding: 4rem 0;">
            <div class="container">
                <h2 class="section-title">Winter Activities</h2>
                <p class="section-subtitle">Beskydy in white</p>
                
                <div class="card-grid">
                    <article class="card">
                        <div class="card-content">
                            <h3 class="card-title">⛷️ Downhill Skiing</h3>
                            <p class="card-description">Modern ski resorts with quality equipment, artificial snow-making and night skiing.</p>
                            <ul class="info-list">
                                <li>Ski resort Lyžařská</li>
                                <li>Ski Ostravice</li>
                                <li>Ski Troják</li>
                                <li>Ski rentals</li>
                                <li>Ski school</li>
                            </ul>
                            <p><strong>Season:</strong> December - March</p>
                            <p><strong>Difficulty:</strong> Easy to challenging</p>
                        </div>
                    </article>
                    
                    <article class="card">
                        <div class="card-content">
                            <h3 class="card-title">🎿 Cross-Country Skiing</h3>
                            <p class="card-description">Hundreds of miles of groomed cross-country trails. Ideal conditions for classic and skating technique.</p>
                            <ul class="info-list">
                                <li>Cross-country trail network</li>
                                <li>Night skiing</li>
                                <li>Groomed trails</li>
                                <li>Ski rentals</li>
                            </ul>
                            <p><strong>Season:</strong> December - March</p>
                            <p><strong>Difficulty:</strong> Easy to moderate</p>
                        </div>
                    </article>
                    
                    <article class="card">
                        <div class="card-content">
                            <h3 class="card-title">🛷 Sledding</h3>
                            <p class="card-description">Fun for the whole family on groomed sledding runs with possibility of evening lighting.</p>
                            <ul class="info-list">
                                <li>Sledding runs</li>
                                <li>Bob run Malenovice</li>
                                <li>Sled rentals</li>
                                <li>Suitable for children</li>
                            </ul>
                            <p><strong>Season:</strong> December - March</p>
                            <p><strong>Difficulty:</strong> Easy</p>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <section class="container">
            <h2 class="section-title">Cultural Activities</h2>
            <p class="section-subtitle">Learn about the rich heritage of Beskydy</p>
            
            <div class="card-grid">
                <article class="card">
                    <div class="card-content">
                        <h3 class="card-title">🎭 Festivals and Events</h3>
                        <p class="card-description">Year-round calendar of cultural events from folklore festivals to modern music concerts.</p>
                        <ul class="info-list">
                            <li>Beskydy Folklore Festival</li>
                            <li>Radegast Day</li>
                            <li>Christmas markets</li>
                            <li>Music festivals</li>
                        </ul>
                    </div>
                </article>
                
                <article class="card">
                    <div class="card-content">
                        <h3 class="card-title">🏛️ Museums and Galleries</h3>
                        <p class="card-description">Learn about the region's history in local museums, galleries and heritage sites.</p>
                        <ul class="info-list">
                            <li>Wallachian Museum</li>
                            <li>Leoš Janáček's birthplace</li>
                            <li>Nový Jičín Museum</li>
                            <li>Art galleries</li>
                        </ul>
                    </div>
                </article>
                
                <article class="card">
                    <div class="card-content">
                        <h3 class="card-title">🍴 Gastronomy</h3>
                        <p class="card-description">Taste traditional Wallachian cuisine with local specialties and regional products.</p>
                        <ul class="info-list">
                            <li>Wallachian frgál (sweet pastry)</li>
                            <li>Yeast buns</li>
                            <li>Sheep cheeses</li>
                            <li>Regional breweries</li>
                        </ul>
                    </div>
                </article>
            </div>
        </section>

        <section style="background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%); color: var(--white); padding: 4rem 0; text-align: center;">
            <div class="container">
                <h2 style="color: var(--white);">Ready for Adventure?</h2>
                <p style="font-size: 1.25rem; margin: 1rem 0 2rem;">Start planning your unforgettable trip to Beskydy</p>
                <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                    <a href="accommodation.html" class="cta-button" style="background: var(--white); color: var(--primary-color);">Find Accommodation</a>
                    <a href="contact.html" class="cta-button">Contact Us</a>
                </div>
            </div>
        </section>
    </main>


                        <li><a href="activities.html">Activities</a></li>
                        <li><a href="contact.html">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Information</h3>
                    <ul>
                        <li><a href="#">Maps</a></li>
                        <li><a href="#">Guide</a></li>
                        <li><a href="#">Transport</a></li>
                        <li><a href="#">News</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Follow Us</h3>
                    <ul>
                        <li><a href="#">Facebook</a></li>
                        <li><a href="#">Instagram</a></li>
                        <li><a href="#">YouTube</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2025 Beskydy Region | Student Project PEF CZU</p>
                <p><strong>Authors:</strong> [GROUP 4] | Educational purposes only</p>
            </div>
        </div>
    </footer>
    <script src="../../js/main.js"></script>
    <script src="../../js/auth.js"></script>
    <script>
        // Load activities from backend database
        async function loadActivities() {
            const grid = document.getElementById('activities-grid');

            try {
                console.log('📡 Fetching activities from backend...');

                const response = await fetch('http://localhost:3001/api/activities');
                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.error || 'Failed to load activities');
                }

                const activities = data.activities;
                console.log(`✅ Loaded ${activities.length} activities`);

                if (activities.length === 0) {
                    grid.innerHTML = `
                        <p style="grid-column: 1 / -1; text-align: center; padding: 2rem; color: #666;">
                            No activities available at the moment.
                        </p>
                    `;
                    return;
                }

                // Display activity cards
                grid.innerHTML = activities.map(act => {
                    const typeEmoji = {
                        'hiking': '🥾',
                        'skiing': '⛷️',
                        'cultural': '🎭',
                        'adventure': '🚵',
                        'relaxation': '🧘'
                    };

                    const emoji = typeEmoji[act.type] || '🏔️';

                    return `
                        <article class="card">
                            ${act.image_url ? `<img src="${act.image_url}" alt="${act.name}" class="card-image">` : ''}
                            <div class="card-content">
                                <h3 class="card-title">${emoji} ${act.name}</h3>
                                <p class="card-description">${act.description || 'Exciting activity in Beskydy region.'}</p>
                                <p><strong>Duration:</strong> ${act.duration || 'Varies'}</p>
                                <p><strong>Difficulty:</strong> ${act.difficulty || 'N/A'}</p>
                                <p><strong>Season:</strong> ${act.season || 'Year-round'}</p>
                                <p><strong>Price:</strong> $${parseFloat(act.price).toFixed(2)}</p>
                                ${act.available ?
                                    `<a href="../booking/booking.html?type=activity&id=${act.id}&item=${encodeURIComponent(act.name)}" class="card-link">Book Now →</a>` :
                                    `<p style="color: #dc3545; font-weight: bold;">Currently Unavailable</p>`
                                }
                            </div>
                        </article>
                    `;
                }).join('');

            } catch (error) {
                console.error('❌ Error loading activities:', error);
                grid.innerHTML = `
                    <div style="grid-column: 1 / -1; text-align: center; padding: 2rem; color: #dc3545;">
                        <p style="font-size: 1.2em; margin-bottom: 1rem;">⚠️ Unable to load activities</p>
                        <p>${error.message}</p>
                        <p style="margin-top: 1rem;">
                            <strong>Possible reasons:</strong><br>
                            • Backend server is not running<br>
                            • Database is not connected<br>
                            • Network connection issue
                        </p>
                        <p style="margin-top: 1rem;">
                            <button onclick="loadActivities()" class="cta-button" style="display: inline-block;">
                                Try Again
                            </button>
                        </p>
                    </div>
                `;
            }
        }

        // Load activities when page loads
        window.addEventListener('DOMContentLoaded', loadActivities);
    </script>
</body>
</html>
